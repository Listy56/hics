<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Warna bayangan (Gradient dari transparan ke abu-abu) -->
    <item>
        <shape>
            <gradient
                android:angle="180"
                android:startColor="#15000000"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- 2. Konten utama (Background putih) -->
    <!-- Kita beri margin top (misal 4dp) agar gradasi di atas terlihat seperti bayangan -->
    <item android:top="6dp">
        <shape>
            <solid android:color="@android:color/white" />
        </shape>
    </item>
</layer-list>