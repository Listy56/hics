<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_home"
    android:padding="16dp"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:text="Control"
        android:fontFamily="@font/poppinmedium"
        android:textColor="@color/hijau_end"
        android:layout_gravity="center"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="2dp"
        android:backgroundTint="@color/white"
        app:cardCornerRadius="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/mode"
                android:layout_marginRight="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mode : "
                android:fontFamily="@font/poppinmedium"
                android:textColor="@color/hijau_end"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Auto"
                android:textStyle="italic"
                android:layout_weight="1"
                android:fontFamily="@font/poppinmedium"
                android:textColor="@color/hijau_end"
                android:textSize="14sp"/>
            <LinearLayout
                android:id="@+id/switchMode"
                android:layout_width="50dp"
                android:layout_height="26dp"
                android:padding="3dp"
                android:layout_marginRight="10dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_switch_off">
                <View
                    android:id="@+id/circleMode"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_circle"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvStatusMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:text="Sistem berjalan otomatis berdasarkan thershold"
        android:textColor="#000000"
        android:fontFamily="@font/poppinsregular"
        android:textStyle="italic"
        android:layout_marginTop="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:weightSum="2">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:weightSum="4"
            android:orientation="vertical"
            android:layout_weight="1">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="2">
                <LinearLayout
                    android:id="@+id/pumpLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="5dp"
                    android:layout_marginBottom="20dp"
                    android:layout_marginLeft="0dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginRight="40dp"
                    android:background="@drawable/bg_button"
                    android:orientation="vertical"
                    android:weightSum="4"
                    app:cardCornerRadius="20dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:paddingLeft="10dp"
                        android:gravity="center_vertical"
                        android:layout_weight="1">
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/pompa_air"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pompa Air"
                            android:layout_marginLeft="5dp"
                            android:fontFamily="@font/poppinmedium"
                            android:textSize="14sp"
                            android:textColor="#08AAA3"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:gravity="center"
                        android:layout_weight="2">
                        <LinearLayout
                            android:id="@+id/switchPump"
                            android:layout_width="50dp"
                            android:layout_height="26dp"
                            android:padding="3dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_switch_off">
                            <View
                                android:id="@+id/circlePump"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_circle"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:gravity="center"
                        android:layout_weight="1">
                        <TextView
                            android:id="@+id/statusSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:fontFamily="@font/poppinsbold"
                            android:textSize="14sp"
                            android:textColor="#08AAA3"/>
                    </LinearLayout>
                </LinearLayout  >
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>